{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "{main.py,config.py,data.py,models.py,plugin.py,utils.py,pyproject.toml,theme/**,plugins/**,data/**}"
    }
  }
}